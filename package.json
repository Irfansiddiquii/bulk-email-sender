{
  "name": "bulk-email-sender",
  "version": "2.0.0",
  "description": "Web-based bulk email sender with user management and WYSIWYG editor",
  "main": "src/app.ts",
  "scripts": {
    "dev": "powershell -Command \"Start-Process -NoNewWindow -FilePath cmd.exe -ArgumentList '/c npm run dev' -WorkingDirectory frontend\" && tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "clean": "rm -rf dist uploads/* logs/* data/users.db",
    "reset-db": "rm -f data/users.db data/scheduler.db",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "email",
    "bulk-email",
    "smtp",
    "nodemailer",
    "bun",
    "typescript",
    "authentication",
    "user-management"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.4.1",
    "argon2": "^0.31.2",
    "csv-stringify": "^6.4.4",
    "dotenv": "^16.3.1",
    "framer-motion": "^12.42.2",
    "hono": "^3.12.0",
    "lucide-svelte": "^1.0.1",
    "motion": "^12.42.2",
    "motion-v": "^2.3.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.8",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^6.4.14",
    "tsx": "^4.23.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  }
}
